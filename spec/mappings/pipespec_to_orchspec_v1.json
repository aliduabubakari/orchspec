{
  "mapping_version": "1.0",
  "source": "pipespec@1.0",
  "target": "orchspec@1.0",
  "executor_mapping": {
    "python": "python_script",
    "bash": "bash",
    "sql": "sql",
    "http": "http_request",
    "container": "container",
    "docker": "container",
    "email": "email",
    "custom": "custom"
  },
  "parameter_type_mapping": {
    "string": "STRING",
    "int": "INT",
    "integer": "INT",
    "float": "FLOAT",
    "boolean": "BOOLEAN",
    "datetime": "DATETIME",
    "date": "DATE",
    "file": "FILE",
    "json": "JSON",
    "array": "ARRAY"
  },
  "field_mapping": {
    "pipeline_summary.name": "metadata.name,pipeline_id",
    "pipeline_summary.description": "description",
    "pipeline_summary.complexity": "metadata.complexity",
    "flow_structure.pattern": "flow.pattern",
    "flow_structure.entry_points": "flow.entry_points",
    "flow_structure.edges": "flow.edges",
    "integrations.connections": "integrations",
    "components[*].executor_type": "components[*].executor.type"
  },
  "determinism_rules": [
    "sort_integrations_by_id",
    "sort_components_by_topological_order_then_id",
    "sort_edges_by_from_to",
    "sort_serialized_keys",
    "omit_empty_optional_fields"
  ],
  "orchestrator_invariants": {
    "imperative_targets": ["airflow", "prefect", "dagster"],
    "declarative_targets": ["kestra", "argo", "kubeflow", "flyte"],
    "required_for_all_targets": [
      "pipeline_id",
      "metadata.name",
      "components[].id",
      "components[].executor.type",
      "flow.pattern",
      "flow.edges"
    ]
  }
}
